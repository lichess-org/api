  "devDependencies": {
    "@redocly/cli": "^2.24.1",
    "@scalar/api-reference": "^1.49.3",
    "@scalar/cli": "^1.7.6",
    "@stoplight/spectral-cli": "^6.15.0",
    "@stoplight/spectral-rulesets": "1.18.1",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-restart": "^2.0.0"
  },
  "scripts": {
    "dev": "pnpm bundle && vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "spectral": "spectral lint --fail-severity=warn specs/*.yaml",
    "lint": "redocly lint specs/lichess-api.yaml",
    "scalar-lint": "pnpm bundle && scalar document lint public/openapi.yaml && scalar document validate public/openapi.yaml",
    "bundle": "redocly bundle specs/lichess-api.yaml --output public/openapi.yaml",
    "format": "prettier . --write",
    "check-format": "prettier . --check"
  }
